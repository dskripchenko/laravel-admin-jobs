{
    "name": "dskripchenko/laravel-admin-jobs",
    "description": "Failed jobs / batches / queue depth viewer для dskripchenko/laravel-admin.",
    "type": "library",
    "keywords": [
        "laravel",
        "admin",
        "queue",
        "failed-jobs",
        "job-batches",
        "workers",
        "dskripchenko"
    ],
    "homepage": "https://github.com/dskripchenko/laravel-admin-jobs",
    "license": "MIT",
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/dskripchenko/laravel-admin-jobs/issues",
        "source": "https://github.com/dskripchenko/laravel-admin-jobs"
    },
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminJobs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminJobs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminJobs\\AdminJobsServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
